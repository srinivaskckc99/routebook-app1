rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate path/document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate the UserBackup schema
    function isValidUserBackup(data) {
      return data.locations is list && 
             data.updatedAt is int &&
             data.updatedAt <= request.time.toMillis() + 300000 &&
             data.keys().hasAll(['locations', 'updatedAt']) &&
             data.keys().size() == 2;
    }

    // Secure users collection rules
    match /users/{userId} {
      allow get: if request.auth != null && 
                    request.auth.uid == userId && 
                    isValidId(userId);
      
      allow create: if request.auth != null && 
                       request.auth.uid == userId && 
                       isValidId(userId) && 
                       request.auth.token.email_verified == true && 
                       isValidUserBackup(request.resource.data);
                       
      allow update: if request.auth != null && 
                       request.auth.uid == userId && 
                       isValidId(userId) && 
                       request.auth.token.email_verified == true && 
                       isValidUserBackup(request.resource.data) && (
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['locations', 'updatedAt'])
                       );
                       
      allow delete: if request.auth != null && 
                       request.auth.uid == userId && 
                       isValidId(userId) && 
                       request.auth.token.email_verified == true;
    }
  }
}
